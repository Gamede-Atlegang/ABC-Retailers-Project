<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ABC Retailers</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ABCRetailers1.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <nav class="glass-nav navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <a class="brand-badge" asp-controller="Home" asp-action="Index">
                        <span class="fw-semibold">ABC Retailers</span>
                        <small class="text-muted d-block">Azure Commerce Hub</small>
                    </a>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <span class="badge bg-dark text-light text-uppercase">@User.Identity?.Name</span>
                    }
                </div>
                <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between mt-3 mt-lg-0" id="mainNav">
                    <ul class="navbar-nav flex-grow-1 gap-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="Index">Customers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Product" asp-action="Index">Products</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="Index">Orders</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Upload" asp-action="Index">Files</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Orders" asp-action="Admin">Admin Board</a>
                            </li>
                        }
                        @if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Store" asp-action="Index">Shop</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cart" asp-action="Index">Cart</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Orders" asp-action="MyOrders">My Orders</a>
                            </li>
                        }
                    </ul>
                    <div class="nav-auth d-flex align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-sm btn-contrast">Sign out</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-light" asp-controller="Account" asp-action="Login">Sign in</a>
                            <a class="btn btn-sm btn-contrast" asp-controller="Account" asp-action="Register">Create account</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="main-shell container-fluid px-4 py-4">
        @RenderBody()
    </main>

    <footer class="app-footer text-center py-4">
        <small>
            &copy; @DateTime.UtcNow.Year ABC Retailers · Built on Azure ·
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </small>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
