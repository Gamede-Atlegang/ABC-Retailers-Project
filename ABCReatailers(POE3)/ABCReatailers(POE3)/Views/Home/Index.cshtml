@model ABCRetailers_POE3_.Models.View_Models.HomeViewModel
@{
	ViewData["Title"] = "Dashboard";
	ViewData["Subtitle"] = "Azure SQL · Storage · Functions";
}

<section class="hero-panel">
	<p class="text-uppercase small text-muted mb-2">Overview</p>
	<h1 class="fw-bold display-5">Hello @User.Identity?.Name 👋</h1>
	<p class="mb-4 text-muted">Monitor your Azure-powered retail experience from a single dashboard.</p>
	<div class="d-flex flex-wrap gap-3">
		@if (User.IsInRole("Admin"))
		{
			<a asp-controller="Customer" asp-action="Create" class="btn btn-primary">Add customer</a>
			<a asp-controller="Product" asp-action="Create" class="btn btn-outline-primary">Add product</a>
			<a asp-controller="Orders" asp-action="Admin" class="btn btn-outline-primary">Review orders</a>
		}
		else if (User.IsInRole("Customer"))
		{
			<a asp-controller="Store" asp-action="Index" class="btn btn-primary">Go shopping</a>
			<a asp-controller="Cart" asp-action="Index" class="btn btn-outline-primary">View cart</a>
		}
	</div>
</section>

<section class="row g-3 mb-4">
	<div class="col-md-4">
		<div class="stat-pill">
			<small class="text-uppercase text-muted">Customers</small>
			<h3>@Model.CustomerCount</h3>
			<p class="mb-0 text-muted">Active profiles across regions</p>
		</div>
	</div>
	<div class="col-md-4">
		<div class="stat-pill">
			<small class="text-uppercase text-muted">Products</small>
			<h3>@Model.ProductCount</h3>
			<p class="mb-0 text-muted">Published SKUs in Azure SQL</p>
		</div>
	</div>
	<div class="col-md-4">
		<div class="stat-pill">
			<small class="text-uppercase text-muted">Orders</small>
			<h3>@Model.OrderCount</h3>
			<p class="mb-0 text-muted">Processed through Functions</p>
		</div>
	</div>
</section>

<section class="app-card mb-4">
	<div class="d-flex justify-content-between align-items-center mb-3">
		<div>
			<h3 class="mb-1">Featured products</h3>
			<p class="text-muted mb-0">Synced from Azure SQL & Storage</p>
		</div>
		@if (User.IsInRole("Admin"))
		{
			<a asp-controller="Product" asp-action="Create" class="btn btn-sm btn-contrast">Add product</a>
		}
	</div>
	@if (Model.FeaturedProducts.Any())
	{
		<div class="store-grid">
			@foreach (var product in Model.FeaturedProducts)
			{
				<div class="product-card">
					<img src="@(!string.IsNullOrWhiteSpace(product.ImageUrl) ? product.ImageUrl : "https://via.placeholder.com/400x250?text=Product")" alt="@product.ProductName" />
					<div class="card-body">
						<h5 class="fw-semibold">@product.ProductName</h5>
						<p class="text-muted small mb-2">@product.Description</p>
						<div class="d-flex justify-content-between align-items-center">
							<span class="fw-bold">@product.Price.ToString("C")</span>
							<span class="badge-soft">Stock @product.StockAvailable</span>
						</div>
					</div>
				</div>
			}
		</div>
	}
	else
	{
		<p class="text-muted mb-0">No products yet. <a asp-controller="Product" asp-action="Create">Add your first product</a>.</p>
	}
</section>