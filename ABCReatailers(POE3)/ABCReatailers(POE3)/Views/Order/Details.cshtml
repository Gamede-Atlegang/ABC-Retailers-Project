@model ABCRetailers_POE3_.Data.Order
@{
	ViewData["Title"] = "Order Details";
}
<h2>Order Details</h2>
<hr />
<div class="row g-3">
	<div class="col-md-6">
		<label class="form-label">Order ID</label>
		<input value="@Model.OrderId" class="form-control" readonly />
	</div>
	<div class="col-md-6">
		<label class="form-label">Order Date</label>
		<input value="@Model.OrderDate.ToString("MM/dd/yyyy HH:mm")" class="form-control" readonly />
	</div>
	<div class="col-md-6">
		<label class="form-label">Customer</label>
		<input value="@($"{Model.Customer?.Name} {Model.Customer?.Surname}")" class="form-control" readonly />
	</div>
	<div class="col-md-6">
		<label class="form-label">Email</label>
		<input value="@Model.Customer?.Email" class="form-control" readonly />
	</div>
	<div class="col-md-6">
		<label class="form-label">Shipping Address</label>
		<textarea class="form-control" rows="2" readonly>@Model.ShippingAddress</textarea>
	</div>
	<div class="col-12">
		<label class="form-label">Items</label>
		<ul class="list-group">
			@foreach (var item in Model.OrderItems)
			{
				<li class="list-group-item d-flex justify-content-between">
					<span>@item.Product?.ProductName ?? item.ProductId.ToString()</span>
					<span>@item.Quantity x @item.UnitPrice.ToString("C2") = @item.TotalPrice.ToString("C2")</span>
				</li>
			}
		</ul>
	</div>
	<div class="col-md-6">
		<label class="form-label">Total Price</label>
		<input value="@Model.TotalPrice.ToString("C2")" class="form-control" readonly />
	</div>
	<div class="col-md-6">
		<label class="form-label">Status</label>
		<input value="@Model.Status" class="form-control" readonly />
	</div>
</div>
<div class="mt-3">
	<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
	<a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>