@model IEnumerable<ABCRetailers_POE3_.Data.Order>
@{
    ViewData["Title"] = "My Orders";
}

<section class="hero text-light mb-4">
    <p class="text-uppercase small text-muted mb-2">Order timeline</p>
    <h1 class="fw-bold mb-2">Your purchases in one view</h1>
    <p class="text-muted mb-0">Track statuses as they move through Azure Functions and SQL replication.</p>
</section>

@if (!Model.Any())
{
    <div class="app-card text-center text-muted">
        <p>No orders yet. Visit the <a asp-controller="Store" asp-action="Index">store</a> to start shopping.</p>
    </div>
}
else
{
    <div class="my-orders-grid">
        @foreach (var order in Model)
        {
            <div class="order-card">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <small>Order</small>
                        <h5 class="mb-0">@order.OrderId</h5>
                    </div>
                    <span class="badge-soft">@order.Status</span>
                </div>
                <small>Placed @order.OrderDate.ToString("dd MMM yyyy HH:mm")</small>
                <hr />
                <ul class="list-unstyled mb-3">
                    @foreach (var item in order.OrderItems)
                    {
                        <li class="d-flex justify-content-between">
                            <span>@item.Product?.ProductName ?? item.ProductId.ToString()</span>
                            <strong>@item.Quantity x @item.UnitPrice.ToString("C")</strong>
                        </li>
                    }
                </ul>
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small>Total paid</small>
                        <h4 class="mb-0">@order.TotalPrice.ToString("C")</h4>
                    </div>
                    <span class="text-muted small">Dispatched to @order.ShippingAddress</span>
                </div>
            </div>
        }
    </div>
}
