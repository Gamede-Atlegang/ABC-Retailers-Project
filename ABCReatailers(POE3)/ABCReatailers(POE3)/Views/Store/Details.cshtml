@model ABCRetailers_POE3_.Data.Product
@{
    ViewData["Title"] = Model.ProductName;
}

<div class="row">
    <div class="col-md-6">
        <img src="@(!string.IsNullOrWhiteSpace(Model.ImageUrl) ? Model.ImageUrl : "https://via.placeholder.com/600x400?text=Product")"
             class="img-fluid rounded" alt="@Model.ProductName" />
    </div>
    <div class="col-md-6">
        <h2>@Model.ProductName</h2>
        <p class="text-muted">@Model.Category</p>
        <p>@Model.Description</p>
        <h4 class="text-primary">@Model.Price.ToString("C")</h4>
        <p>Stock available: <strong>@Model.StockAvailable</strong></p>

        @if (User.IsInRole("Customer"))
        {
            <form asp-controller="Store" asp-action="AddToCart" method="post" class="mt-3">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="input-group input-group-lg mb-3" style="max-width: 250px;">
                    <input type="number" name="quantity" value="1" min="1" max="@Model.StockAvailable" class="form-control" />
                    <button type="submit" class="btn btn-primary">Add to Cart</button>
                </div>
            </form>
        }
        else
        {
            <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Login">Sign in to order</a>
        }

        <a asp-action="Index" class="btn btn-link mt-3">&larr; Back to products</a>
    </div>
</div>

