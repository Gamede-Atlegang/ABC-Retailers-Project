@model IEnumerable<ABCRetailers_POE3_.Data.Product>
@{
    ViewData["Title"] = "Store";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div>
        <h1 class="h3 fw-semibold mb-1">Browse Products</h1>
        <p class="text-muted mb-0">Select items, add them to your cart, and check out securely.</p>
    </div>
    <div class="mt-3 mt-md-0">
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <a class="btn btn-outline-secondary me-2 mb-2 mb-md-0" asp-controller="Cart" asp-action="Index">My Cart</a>
            <a class="btn btn-outline-secondary" asp-controller="Orders" asp-action="MyOrders">My Orders</a>
        }
        else
        {
            <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">Sign in</a>
        }
    </div>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <img src="@(!string.IsNullOrWhiteSpace(product.ImageUrl) ? product.ImageUrl : "https://via.placeholder.com/320x180?text=Product")"
                     class="card-img-top rounded-top" alt="@product.ProductName" style="height:180px; object-fit:cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@product.ProductName</h5>
                    <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-bold fs-5 text-primary">@product.Price.ToString("C")</span>
                        <span class="badge @(product.StockAvailable == 0 ? "bg-danger" : product.StockAvailable < 5 ? "bg-warning text-dark" : "bg-success")">
                            Stock: @product.StockAvailable
                        </span>
                    </div>

                    @if (User.IsInRole("Customer"))
                    {
                        <form asp-action="AddToCart" method="post" class="mt-auto">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <div class="input-group">
                                <input type="number" name="quantity" value="1" min="1" max="10" class="form-control" />
                                <button type="submit" class="btn btn-primary">Add to Cart</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-light border mt-auto">
                            <p class="mb-1 small text-muted">Sign in as a customer to purchase this item.</p>
                            <a class="btn btn-sm btn-outline-primary w-100" asp-controller="Account" asp-action="Login">Sign in</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

