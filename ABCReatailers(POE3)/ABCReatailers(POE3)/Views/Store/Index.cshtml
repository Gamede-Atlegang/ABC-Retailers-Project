@model IEnumerable<ABCRetailers_POE3_.Data.Product>
@{
    ViewData["Title"] = "Store";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-semibold mb-0">Browse Products</h1>
        <p class="text-muted mb-0">Add products to your cart and place an order securely.</p>
    </div>
    <div>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <a class="btn btn-outline-secondary me-2" asp-controller="Cart" asp-action="Index">My Cart</a>
            <a class="btn btn-outline-secondary" asp-controller="Orders" asp-action="MyOrders">My Orders</a>
        }
        else
        {
            <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">Sign in</a>
        }
    </div>
    }

@if (TempData["Message"] is string message)
{
        <div class="alert alert-success">@message</div>
}

@if (TempData["Error"] is string error)
{
        <div class="alert alert-danger">@error</div>
}

    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <img src="@(!string.IsNullOrWhiteSpace(product.ImageUrl) ? product.ImageUrl : "https://via.placeholder.com/400x250?text=Product")"
                         class="card-img-top" alt="@product.ProductName" style="height:220px; object-fit:cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.ProductName</h5>
                        <p class="card-text text-muted flex-grow-1">@product.Description</p>
                        <p class="fw-bold fs-5 mb-1">@product.Price.ToString("C")</p>
                        <p class="text-muted mb-3">Stock: @product.StockAvailable</p>

                        @if (User.IsInRole("Customer"))
                        {
                            <form asp-action="AddToCart" method="post" class="mt-auto">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <div class="input-group">
                                    <input type="number" name="quantity" value="1" min="1" max="10" class="form-control" />
                                    <button type="submit" class="btn btn-primary">Add to Cart</button>
                                </div>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary mt-auto" asp-controller="Account" asp-action="Login">
                                Sign in to purchase
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

